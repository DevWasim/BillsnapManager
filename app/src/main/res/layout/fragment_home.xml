<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorPageBackground"
    android:padding="28dp">

    <!-- Settings (top-left) -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSettings"
        style="@style/Widget.Material3.Button.IconButton"
        android:layout_width="48dp"
        android:layout_height="48dp"
        app:icon="@drawable/ic_settings"
        app:iconTint="?attr/colorTextPrimary"
        android:contentDescription="@string/settings"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Dashboard (top-right) -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnDashboard"
        style="@style/Widget.Material3.Button.IconButton"
        android:layout_width="48dp"
        android:layout_height="48dp"
        app:icon="@drawable/ic_dashboard"
        app:iconTint="?attr/colorTextPrimary"
        android:contentDescription="@string/dashboard"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- App Logo / Title -->
    <TextView
        android:id="@+id/tvAppTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textSize="36sp"
        android:textStyle="bold"
        android:textColor="?attr/colorTextPrimary"
        android:fontFamily="sans-serif-medium"
        app:layout_constraintBottom_toTopOf="@id/tvSubtitle"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_chainStyle="packed" />

    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/home_subtitle"
        android:textSize="14sp"
        android:textColor="?attr/colorTextSecondary"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvAppTitle"
        app:layout_constraintBottom_toTopOf="@id/btnCamera" />

    <!-- Camera Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnCamera"
        android:layout_width="0dp"
        android:layout_height="68dp"
        android:layout_marginTop="40dp"
        android:text="@string/camera"
        android:textSize="17sp"
        android:textAllCaps="false"
        android:textColor="?attr/colorTextPrimary"
        app:backgroundTint="?attr/colorButtonPrimary"
        app:icon="@drawable/ic_camera"
        app:iconSize="26dp"
        app:iconGravity="textStart"
        app:iconPadding="12dp"
        app:iconTint="?attr/colorTextPrimary"
        app:cornerRadius="18dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvSubtitle"
        app:layout_constraintBottom_toTopOf="@id/btnGallery" />

    <!-- Gallery Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnGallery"
        android:layout_width="0dp"
        android:layout_height="68dp"
        android:layout_marginTop="14dp"
        android:text="@string/gallery"
        android:textSize="17sp"
        android:textAllCaps="false"
        android:textColor="?attr/colorTextPrimary"
        app:backgroundTint="?attr/colorCardSurface"
        app:strokeColor="?attr/colorCardStroke"
        app:strokeWidth="1dp"
        app:icon="@drawable/ic_gallery"
        app:iconSize="26dp"
        app:iconGravity="textStart"
        app:iconPadding="12dp"
        app:iconTint="?attr/colorAccentLight"
        app:cornerRadius="18dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnCamera"
        app:layout_constraintBottom_toTopOf="@id/btnProfiles" />

    <!-- Profiles Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnProfiles"
        android:layout_width="0dp"
        android:layout_height="68dp"
        android:layout_marginTop="14dp"
        android:text="@string/profiles"
        android:textSize="17sp"
        android:textAllCaps="false"
        android:textColor="?attr/colorTextPrimary"
        app:backgroundTint="?attr/colorCardSurface"
        app:strokeColor="?attr/colorCardStroke"
        app:strokeWidth="1dp"
        app:icon="@drawable/ic_profiles"
        app:iconSize="26dp"
        app:iconGravity="textStart"
        app:iconPadding="12dp"
        app:iconTint="?attr/colorAccentLight"
        app:cornerRadius="18dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnGallery"
        app:layout_constraintBottom_toTopOf="@id/btnWorkers" />

    <!-- Workers Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnWorkers"
        android:layout_width="0dp"
        android:layout_height="68dp"
        android:layout_marginTop="14dp"
        android:text="Workers"
        android:textSize="17sp"
        android:textAllCaps="false"
        android:textColor="?attr/colorTextPrimary"
        app:backgroundTint="?attr/colorCardSurface"
        app:strokeColor="?attr/colorCardStroke"
        app:strokeWidth="1dp"
        app:icon="@drawable/ic_workers"
        app:iconSize="26dp"
        app:iconGravity="textStart"
        app:iconPadding="12dp"
        app:iconTint="?attr/colorAccentLight"
        app:cornerRadius="18dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnProfiles"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Pending overlay -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutPending"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="?attr/colorPageBackground"
        android:visibility="gone"
        android:translationZ="10dp"
        app:layout_constraintTop_toBottomOf="@id/tvSubtitle"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvPending"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pending Manager Approval"
            android:textSize="20sp"
            android:textColor="?attr/colorTextPrimary"
            android:textAlignment="center"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tvPendingSub"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="You will not be able to access the shop until the owner approves your request."
            android:textSize="14sp"
            android:textColor="?attr/colorTextSecondary"
            android:textAlignment="center"
            app:layout_constraintTop_toBottomOf="@id/tvPending"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
