<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="16dp"
    android:padding="20dp"
    android:background="@drawable/bg_share_pay_card">

    <ImageView
        android:id="@+id/ivPaymentIcon"
        android:layout_width="24dp"
        android:layout_height="24dp"
        app:tint="@color/share_label_muted"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:contentDescription="@null"
        tools:src="@drawable/ic_bank" />

    <TextView
        android:id="@+id/methodName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textSize="16sp"
        android:textColor="@color/share_white"
        android:maxLines="1"
        android:ellipsize="end"
        android:layout_marginStart="14dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toEndOf="@id/ivPaymentIcon"
        app:layout_constraintEnd_toEndOf="parent"
        tools:text="Bank Account" />

    <TextView
        android:id="@+id/methodNumber"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textSize="14sp"
        android:textColor="@color/share_label_muted"
        android:maxLines="1"
        android:ellipsize="end"
        android:layout_marginStart="14dp"
        android:layout_marginTop="2dp"
        app:layout_constraintTop_toBottomOf="@id/methodName"
        app:layout_constraintStart_toEndOf="@id/ivPaymentIcon"
        app:layout_constraintEnd_toEndOf="parent"
        tools:text="1234567890" />
</androidx.constraintlayout.widget.ConstraintLayout>
