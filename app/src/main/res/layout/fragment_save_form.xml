<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorPageBackground"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Image Preview -->
        <ImageView
            android:id="@+id/ivPreview"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:scaleType="centerCrop"
            android:contentDescription="@string/captured_image" />

        <!-- Form Container -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="22dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/save_details"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="?attr/colorTextPrimary"
                android:layout_marginBottom="20dp" />

            <!-- Name Field -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilName"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/name_hint"
                app:errorEnabled="true"
                app:hintTextColor="#77FFFFFF"
                app:boxStrokeColor="#7C4DFF"
                app:boxBackgroundColor="?attr/colorInputBackground"
                app:boxCornerRadiusTopStart="14dp"
                app:boxCornerRadiusTopEnd="14dp"
                app:boxCornerRadiusBottomStart="14dp"
                app:boxCornerRadiusBottomEnd="14dp"
                android:layout_marginBottom="12dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPersonName"
                    android:textColor="?attr/colorTextPrimary"
                    android:maxLines="1" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Notes Field -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilNotes"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/notes_hint"
                app:hintTextColor="#77FFFFFF"
                app:boxStrokeColor="#2E3140"
                app:boxBackgroundColor="?attr/colorInputBackground"
                app:boxCornerRadiusTopStart="14dp"
                app:boxCornerRadiusTopEnd="14dp"
                app:boxCornerRadiusBottomStart="14dp"
                app:boxCornerRadiusBottomEnd="14dp"
                android:layout_marginBottom="16dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etNotes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textMultiLine"
                    android:textColor="?attr/colorTextSecondary"
                    android:minLines="3"
                    android:gravity="top" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Total Amount Field -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilTotalAmount"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Total Amount"
                app:hintTextColor="#77FFFFFF"
                app:boxStrokeColor="#7C4DFF"
                app:boxBackgroundColor="?attr/colorInputBackground"
                app:boxCornerRadiusTopStart="14dp"
                app:boxCornerRadiusTopEnd="14dp"
                app:boxCornerRadiusBottomStart="14dp"
                app:boxCornerRadiusBottomEnd="14dp"
                app:errorEnabled="true"
                app:startIconDrawable="@drawable/ic_money"
                app:startIconTint="#B388FF"
                android:layout_marginBottom="12dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etTotalAmount"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="numberDecimal"
                    android:textColor="?attr/colorTextPrimary"
                    android:maxLines="1" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Paid Amount Field -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilPaidAmount"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Paid Amount"
                app:helperTextEnabled="true"
                app:helperText="Remaining: 0.00"
                app:helperTextTextColor="#69F0AE"
                app:hintTextColor="#77FFFFFF"
                app:boxStrokeColor="#2E3140"
                app:boxBackgroundColor="?attr/colorInputBackground"
                app:boxCornerRadiusTopStart="14dp"
                app:boxCornerRadiusTopEnd="14dp"
                app:boxCornerRadiusBottomStart="14dp"
                app:boxCornerRadiusBottomEnd="14dp"
                app:errorEnabled="true"
                app:startIconDrawable="@drawable/ic_check"
                app:startIconTint="#69F0AE"
                android:layout_marginBottom="16dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etPaidAmount"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="numberDecimal"
                    android:textColor="?attr/colorTextPrimary"
                    android:text="0"
                    android:maxLines="1" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Customer Dropdown -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilCustomer"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/customer_hint"
                app:hintTextColor="#77FFFFFF"
                app:boxStrokeColor="#2E3140"
                app:boxBackgroundColor="?attr/colorInputBackground"
                app:boxCornerRadiusTopStart="14dp"
                app:boxCornerRadiusTopEnd="14dp"
                app:boxCornerRadiusBottomStart="14dp"
                app:boxCornerRadiusBottomEnd="14dp"
                android:layout_marginBottom="16dp">

                <AutoCompleteTextView
                    android:id="@+id/actvCustomer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="none"
                    android:textColor="?attr/colorTextPrimary"
                    android:maxLines="1" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Payment Status -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/payment_status"
                android:textSize="14sp"
                android:textColor="?attr/colorTextSecondary"
                android:layout_marginBottom="8dp" />

            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/toggleStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:singleSelection="true"
                app:selectionRequired="true"
                android:layout_marginBottom="20dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnUnpaid"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="@string/unpaid"
                    android:textAllCaps="false"
                    android:textColor="?attr/colorDangerText"
                    app:strokeColor="?attr/colorDangerText" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPaid"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="@string/paid"
                    android:textAllCaps="false"
                    android:textColor="@color/status_paid"
                    app:strokeColor="@color/status_paid" />

            </com.google.android.material.button.MaterialButtonToggleGroup>

            <!-- Reminder Toggle -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/set_reminder"
                    android:textSize="15sp"
                    android:textColor="?attr/colorTextSecondary" />

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switchReminder"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <!-- Reminder Date/Time -->
            <LinearLayout
                android:id="@+id/layoutReminder"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:visibility="gone"
                android:layout_marginBottom="20dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPickDate"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:text="@string/pick_date"
                    android:textAllCaps="false"
                    android:textColor="?attr/colorTextPrimary"
                    app:backgroundTint="?attr/colorCardSurface"
                    app:strokeColor="?attr/colorCardStroke"
                    app:strokeWidth="1dp"
                    app:icon="@drawable/ic_calendar"
                    app:iconTint="?attr/colorAccentLight"
                    app:cornerRadius="12dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPickTime"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="@string/pick_time"
                    android:textAllCaps="false"
                    android:textColor="?attr/colorTextPrimary"
                    app:backgroundTint="?attr/colorCardSurface"
                    app:strokeColor="?attr/colorCardStroke"
                    app:strokeWidth="1dp"
                    app:icon="@drawable/ic_clock"
                    app:iconTint="?attr/colorAccentLight"
                    app:cornerRadius="12dp" />
            </LinearLayout>

            <!-- Progress -->
            <com.google.android.material.progressindicator.LinearProgressIndicator
                android:id="@+id/progressBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:indeterminate="true"
                android:visibility="gone"
                android:layout_marginBottom="12dp" />

            <!-- Save Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSave"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="@string/save_bill"
                android:textSize="16sp"
                android:textAllCaps="false"
                android:textColor="?attr/colorTextPrimary"
                app:backgroundTint="?attr/colorButtonPrimary"
                app:cornerRadius="16dp" />

        </LinearLayout>
    </LinearLayout>
</ScrollView>
