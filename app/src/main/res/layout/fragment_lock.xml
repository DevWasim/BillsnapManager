<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorPageBackground">

    <ImageView
        android:id="@+id/ivLockIcon"
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:src="@drawable/ic_camera"
        app:tint="#7C4DFF"
        android:contentDescription="@string/app_locked"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tvLockTitle"
        app:layout_constraintVertical_chainStyle="packed" />

    <TextView
        android:id="@+id/tvLockTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/app_locked"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="?attr/colorTextPrimary"
        app:layout_constraintTop_toBottomOf="@id/ivLockIcon"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tvPinPrompt" />

    <TextView
        android:id="@+id/tvPinPrompt"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/enter_pin_to_unlock"
        android:textSize="14sp"
        android:textColor="?attr/colorTextSecondary"
        app:layout_constraintTop_toBottomOf="@id/tvLockTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tilPin" />

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilPin"
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:hint="@string/enter_pin"
        app:hintTextColor="#77FFFFFF"
        app:boxStrokeColor="#7C4DFF"
        app:boxBackgroundColor="?attr/colorInputBackground"
        app:boxCornerRadiusTopStart="14dp"
        app:boxCornerRadiusTopEnd="14dp"
        app:boxCornerRadiusBottomStart="14dp"
        app:boxCornerRadiusBottomEnd="14dp"
        app:layout_constraintTop_toBottomOf="@id/tvPinPrompt"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/btnUnlock">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etPin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="numberPassword"
            android:maxLength="4"
            android:gravity="center"
            android:textColor="?attr/colorTextPrimary"
            android:textSize="24sp" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnUnlock"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/enter_pin"
        android:textAllCaps="false"
        android:textColor="?attr/colorTextPrimary"
        app:backgroundTint="?attr/colorButtonPrimary"
        app:cornerRadius="14dp"
        app:layout_constraintTop_toBottomOf="@id/tilPin"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/btnFingerprint" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnFingerprint"
        style="@style/Widget.Material3.Button.TextButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/unlock_with_fingerprint"
        android:textAllCaps="false"
        android:textColor="?attr/colorAccentLight"
        app:layout_constraintTop_toBottomOf="@id/btnUnlock"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <TextView
        android:id="@+id/tvError"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/status_unpaid"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/btnFingerprint"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
