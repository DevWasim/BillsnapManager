    </style>
    <style name="Urdu.LabelMedium" parent="TextAppearance.Material3.LabelMedium">
        <item name="android:fontFamily">@font/nastaliq_family</item>
        <item name="android:textSize">10sp</item>
    </style>
    <style name="Urdu.LabelSmall" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:fontFamily">@font/nastaliq_family</item>
        <item name="android:textSize">9sp</item>
    </style>
</resources>
