<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorPageBackground"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="32dp">

        <!-- ═══════════════════════════════════════ -->
        <!-- HEADER GRADIENT BANNER: Global Summary  -->
        <!-- ═══════════════════════════════════════ -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_dashboard_header">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="20dp"
                android:paddingTop="16dp"
                android:paddingBottom="24dp">

                <!-- Top bar row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnBack"
                        style="@style/Widget.Material3.Button.IconButton"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        app:icon="@drawable/ic_back"
                        app:iconTint="?attr/colorTextPrimary" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="4dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Financial Analytics"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:textColor="?attr/colorTextPrimary" />

                        <TextView
                            android:id="@+id/tvDashboardDate"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="12sp"
                            android:textColor="?attr/colorTextSecondary"
                            android:text="Global Summary" />
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnExport"
                        style="@style/Widget.Material3.Button.IconButton"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        app:icon="@drawable/ic_export"
                        app:iconTint="?attr/colorTextPrimary" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="16dp"/>

                <!-- ─── GLOBAL FINANCIAL HERO CARDS ─── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Total Billed block -->
                    <LinearLayout
                        android:id="@+id/cardTotalBills"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1.3"
                        android:orientation="vertical"
                        android:background="@drawable/bg_hero_card"
                        android:padding="16dp"
                        android:layout_marginEnd="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="💰 Total"
                            android:textSize="11sp"
                            android:textColor="?attr/colorTextSecondary"
                            android:layout_marginBottom="4dp"/>

                        <TextView
                            android:id="@+id/tvTotalBills"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="$0"
                            android:textSize="32sp"
                            android:textStyle="bold"
                            android:textColor="?attr/colorTextPrimary" />

                        <TextView
                            android:id="@+id/tvGrowthLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="11sp"
                            android:textColor="@color/status_paid"
                            android:text="Life Time" />
                    </LinearLayout>

                    <!-- Paid + Remaining -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <LinearLayout
                            android:id="@+id/cardPaid"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:background="@drawable/bg_stat_mini_paid"
                            android:padding="10dp"
                            android:layout_marginBottom="8dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="✅ Total Paid"
                                android:textSize="10sp"
                                android:textColor="@color/status_paid" />

                            <TextView
                                android:id="@+id/tvPaidCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="$0"
                                android:textSize="20sp"
                                android:textStyle="bold"
                                android:textColor="?attr/colorTextPrimary" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/cardUnpaid"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:background="@drawable/bg_stat_mini_unpaid"
                            android:padding="10dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="⚠️ Remaining"
                                android:textSize="10sp"
                                android:textColor="#F44336" />

                            <TextView
                                android:id="@+id/tvUnpaidCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="$0"
                                android:textSize="20sp"
                                android:textStyle="bold"
                                android:textColor="#F44336" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>
        </FrameLayout>

        <!-- ═══════════════════════════════════════ -->
        <!-- SECONDARY STAT ROW (Overdue + Customers)-->
        <!-- ═══════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="4dp">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardOverdue"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="?attr/colorCardSurface"
                app:strokeWidth="1dp"
                app:strokeColor="@color/status_overdue">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔴 Overdue Value"
                        android:textSize="10sp"
                        android:textColor="@color/status_overdue"
                        android:layout_marginBottom="2dp" />

                    <TextView
                        android:id="@+id/tvOverdueCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="$0"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="@color/status_overdue" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardDueSoon"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="?attr/colorCardSurface"
                app:strokeWidth="1dp"
                app:strokeColor="@color/status_due_soon">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🧾 Total Bills"
                        android:textSize="10sp"
                        android:textColor="@color/status_due_soon"
                        android:layout_marginBottom="2dp" />

                    <TextView
                        android:id="@+id/tvDueSoonCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="@color/status_due_soon" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardCustomers"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="?attr/colorCardSurface"
                app:strokeWidth="1dp"
                app:strokeColor="?attr/colorAccentPrimary">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="👥 Customers"
                        android:textSize="10sp"
                        android:textColor="?attr/colorAccentLight"
                        android:layout_marginBottom="2dp" />

                    <TextView
                        android:id="@+id/tvCustomerCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="?attr/colorAccentPrimary" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- ═══════════════════════════════════════ -->
        <!-- CURRENT MONTH ANALYTICS MODULE          -->
        <!-- ═══════════════════════════════════════ -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="?attr/colorCardSurface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Current Month Progress"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorTextPrimary"
                    android:layout_marginBottom="16dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <!-- Progress Ring -->
                    <com.billsnap.manager.ui.dashboard.ProgressRingView
                        android:id="@+id/progressRing"
                        android:layout_width="120dp"
                        android:layout_height="120dp"
                        android:layout_marginEnd="20dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Total this month"
                            android:textSize="11sp"
                            android:textColor="?attr/colorTextSecondary"/>
                        <TextView
                            android:id="@+id/tvMonthBilled"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="$0"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="?attr/colorTextPrimary"
                            android:layout_marginBottom="8dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Collected"
                            android:textSize="11sp"
                            android:textColor="@color/status_paid"/>
                        <TextView
                            android:id="@+id/tvMonthCollected"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="$0"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="@color/status_paid"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ═══════════════════════════════════════ -->
        <!-- PAYMENT STATUS DISTRIBUTION DONUT       -->
        <!-- ═══════════════════════════════════════ -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="?attr/colorCardSurface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">
                
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="16dp">
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Status Distribution"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="?attr/colorTextPrimary"
                        android:layout_marginBottom="12dp"/>
                        
                    <TextView
                        android:id="@+id/tvDonutLegend"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Paid: 0\nUnpaid: 0\nOverdue: 0\nPartial: 0"
                        android:textSize="13sp"
                        android:lineSpacingExtra="4dp"
                        android:textColor="?attr/colorTextSecondary" />
                </LinearLayout>

                <com.billsnap.manager.ui.dashboard.DonutChartView
                    android:id="@+id/donutChart"
                    android:layout_width="120dp"
                    android:layout_height="120dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ═══════════════════════════════════════ -->
        <!-- REDESIGNED TRENDS: MONTHLY CHART        -->
        <!-- ═══════════════════════════════════════ -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardChart"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="?attr/colorCardSurface"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tvChartTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Monthly Paid vs Total"
                    android:textAppearance="?attr/textAppearanceTitleMedium"
                    android:textColor="?attr/colorOnSurface"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <View
                    android:id="@+id/indicatorTotal"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:layout_marginEnd="6dp"
                    android:background="?attr/colorTertiary"
                    app:layout_constraintBottom_toBottomOf="@+id/tvChartTitle"
                    app:layout_constraintEnd_toStartOf="@+id/tvIndicatorTotal"
                    app:layout_constraintTop_toTopOf="@+id/tvChartTitle" />

                <TextView
                    android:id="@+id/tvIndicatorTotal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="12dp"
                    android:text="Total"
                    android:textSize="11sp"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    app:layout_constraintBottom_toBottomOf="@+id/tvChartTitle"
                    app:layout_constraintEnd_toStartOf="@+id/indicatorPaid"
                    app:layout_constraintTop_toTopOf="@+id/tvChartTitle" />

                <View
                    android:id="@+id/indicatorPaid"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:layout_marginEnd="6dp"
                    android:background="?attr/colorPrimary"
                    app:layout_constraintBottom_toBottomOf="@+id/tvChartTitle"
                    app:layout_constraintEnd_toStartOf="@+id/tvIndicatorPaid"
                    app:layout_constraintTop_toTopOf="@+id/tvChartTitle" />

                <TextView
                    android:id="@+id/tvIndicatorPaid"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Paid"
                    android:textSize="11sp"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    app:layout_constraintBottom_toBottomOf="@+id/tvChartTitle"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@+id/tvChartTitle" />

                <com.billsnap.manager.ui.dashboard.BarChartView
                    android:id="@+id/barChart"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_marginTop="12dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/tvChartTitle" />
            </androidx.constraintlayout.widget.ConstraintLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- ═══════════════════════════════════════ -->
        <!-- MONTH DRILL-DOWN PANEL (Compact Design) -->
        <!-- ═══════════════════════════════════════ -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/layoutMonthHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="8dp"
            android:visibility="gone"
            tools:visibility="visible">

            <TextView
                android:id="@+id/tvMonthDetailTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:textAppearance="?attr/textAppearanceTitleMedium"
                android:textColor="?attr/colorOnSurface"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/tvMonthDetailCount"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                tools:text="February 2026" />

            <TextView
                android:id="@+id/tvMonthDetailCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_pill_surface_variant"
                android:paddingHorizontal="12dp"
                android:paddingVertical="4dp"
                android:textAppearance="?attr/textAppearanceLabelSmall"
                android:textColor="?attr/colorOnSurfaceVariant"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                tools:text="14 Bills" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Bill List -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvMonthBills"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:clipToPadding="false"
            android:nestedScrollingEnabled="false"
            android:paddingHorizontal="16dp"
            android:visibility="gone"
            tools:listitem="@layout/item_month_bill"
            tools:visibility="visible" />

        <!-- Empty State -->
        <TextView
            android:id="@+id/tvEmptyState"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="48dp"
            android:layout_marginBottom="16dp"
            android:gravity="center"
            android:text="Tap a month chart bar to view bills"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:textColor="?attr/colorOnSurfaceVariant" />

        <!-- ═══════════════════════════════════════ -->
        <!-- CUSTOMER LEADERBOARD                    -->
        <!-- ═══════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="20dp"
            android:paddingTop="20dp"
            android:paddingBottom="4dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Top Customers"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="?attr/colorTextPrimary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Financial Value"
                android:textSize="11sp"
                android:textColor="?attr/colorTextHint" />
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvTopCustomers"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="4dp"
            android:nestedScrollingEnabled="false"
            android:clipToPadding="false" />

        <TextView
            android:id="@+id/tvNoCustomers"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No customers yet"
            android:textSize="13sp"
            android:textColor="?attr/colorTextHint"
            android:gravity="center"
            android:padding="20dp"
            android:visibility="gone" />

    </LinearLayout>
</ScrollView>
