<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorPageBackground">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorPageBackground"
        app:elevation="0dp"
        app:layout_constraintTop_toTopOf="parent">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="?attr/colorPageBackground"
            app:title="Worker Details"
            app:titleTextColor="#FFFFFFFF"
            app:navigationIconTint="#FFFFFFFF"
            app:navigationIcon="@drawable/ic_back" />
    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/appBarLayout"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Worker Info Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="?attr/colorCardSurface"
                app:strokeWidth="1dp"
                app:strokeColor="?attr/colorCardStroke"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tvName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Worker Name"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="?attr/colorTextPrimary" />

                    <TextView
                        android:id="@+id/tvEmail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="worker@email.com"
                        android:textSize="14sp"
                        android:textColor="?attr/colorTextSecondary"
                        android:layout_marginTop="4dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="12dp">

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipRole"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Worker"
                            app:chipBackgroundColor="#2D1B69"
                            android:textColor="?attr/colorAccentLight" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="Pending"
                            app:chipBackgroundColor="#2D1B00"
                            android:textColor="?attr/colorAccentLight" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Pending Action Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardPendingActions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="?attr/colorCardSurface"
                app:strokeWidth="1dp"
                app:strokeColor="?attr/colorDangerText"
                android:layout_marginBottom="24dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Action Required"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="?attr/colorTextPrimary" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="This worker has joined via an invite link and is waiting for your approval to access the shop."
                        android:textSize="14sp"
                        android:textColor="?attr/colorTextSecondary"
                        android:layout_marginTop="8dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnApprove"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Approve Access"
                        android:textColor="?attr/colorTextPrimary"
                        app:backgroundTint="?attr/colorButtonPrimary"
                        app:cornerRadius="12dp"
                        android:layout_marginTop="16dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/tvPermissionsTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Permissions"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="?attr/colorAccentPrimary"
                android:textAllCaps="true"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp" />

            <!-- Permissions Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardPermissions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="?attr/colorCardSurface"
                app:strokeWidth="1dp"
                app:strokeColor="?attr/colorCardStroke"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchViewBills"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="View Bills (Gallery)"
                        android:textColor="?attr/colorTextSecondary"
                        android:padding="8dp" />

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchCreateBills"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Create Bills (Camera)"
                        android:textColor="?attr/colorTextSecondary"
                        android:padding="8dp" />

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchEditBills"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Edit Bill Status"
                        android:textColor="?attr/colorTextSecondary"
                        android:padding="8dp" />

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchDeleteBills"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Delete Bills"
                        android:textColor="?attr/colorTextSecondary"
                        android:padding="8dp" />

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchExportBills"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Export Bills (PDF)"
                        android:textColor="?attr/colorTextSecondary"
                        android:padding="8dp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="?attr/colorDivider"
                        android:layout_marginVertical="8dp"/>

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchViewCustomers"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="View Customers (Profiles)"
                        android:textColor="?attr/colorTextSecondary"
                        android:padding="8dp" />

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchCreateCustomers"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Add Customer Profiles"
                        android:textColor="?attr/colorTextSecondary"
                        android:padding="8dp" />

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchEditCustomers"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Edit Customer Profiles"
                        android:textColor="?attr/colorTextSecondary"
                        android:padding="8dp" />

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchDeleteCustomers"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Delete Customers"
                        android:textColor="?attr/colorTextSecondary"
                        android:padding="8dp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="?attr/colorDivider"
                        android:layout_marginVertical="8dp"/>

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchViewDashboard"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="View Dashboard"
                        android:textColor="?attr/colorTextSecondary"
                        android:padding="8dp" />

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchManageWorkers"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Manage Workers"
                        android:textColor="?attr/colorTextSecondary"
                        android:padding="8dp" />

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchViewLogs"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="View Activity Logs"
                        android:textColor="?attr/colorTextSecondary"
                        android:padding="8dp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="?attr/colorDivider"
                        android:layout_marginVertical="8dp"/>

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchFullAccess"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Full Access (All Permissions)"
                        android:textStyle="bold"
                        android:textColor="?attr/colorAccentLight"
                        android:padding="8dp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnViewLogs"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="View Activity Logs"
                android:textColor="?attr/colorTextPrimary"
                app:backgroundTint="?attr/colorCardSurface"
                app:strokeColor="?attr/colorAccentPrimary"
                app:strokeWidth="1dp"
                app:cornerRadius="12dp"
                android:layout_marginBottom="16dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRemoveWorker"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Remove Worker"
                android:textColor="?attr/colorDangerText"
                app:backgroundTint="?attr/colorCardSurface"
                app:strokeColor="?attr/colorDangerText"
                app:strokeWidth="1dp"
                app:cornerRadius="12dp" />

        </LinearLayout>
    </ScrollView>

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
