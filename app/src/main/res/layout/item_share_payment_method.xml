<?xml version="1.0" encoding="utf-8"?>
<!--
    Reusable payment method row for share card images.
    Included up to 3 times in each share card layout.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/rootPaymentMethod"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="20px"
    android:background="@drawable/bg_share_payment_item">

    <ImageView
        android:id="@+id/ivPaymentIcon"
        android:layout_width="40px"
        android:layout_height="40px"
        android:src="@drawable/ic_bank"
        android:contentDescription="@string/payment_methods"
        android:layout_marginEnd="16px" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvPaymentMethodName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAppearance="?attr/textAppearanceLabelMedium"
            android:textColor="?attr/colorOnSurface"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"
            tools:text="Bank Account" />

        <TextView
            android:id="@+id/tvPaymentAccountTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAppearance="?attr/textAppearanceLabelSmall"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:maxLines="1"
            android:ellipsize="end"
            tools:text="Muhammad Ali Khan" />

        <TextView
            android:id="@+id/tvPaymentAccountNumber"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAppearance="?attr/textAppearanceBodySmall"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:maxLines="1"
            android:ellipsize="end"
            android:layout_marginTop="2px"
            tools:text="PK36SCBL0000001234567890" />
    </LinearLayout>
</LinearLayout>
