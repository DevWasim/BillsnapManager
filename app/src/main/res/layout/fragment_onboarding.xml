<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="?attr/colorPageBackground"
    android:padding="32dp">

    <!-- Logo / Icon -->
    <ImageView
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:src="@drawable/ic_camera"
        app:tint="#7C4DFF"
        android:layout_marginBottom="24dp"
        android:contentDescription="BillSnap" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Welcome to BillSnap"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="?attr/colorTextPrimary"
        android:layout_marginBottom="12dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Choose how you want to use the app"
        android:textSize="16sp"
        android:textColor="?attr/colorTextSecondary"
        android:gravity="center"
        android:layout_marginBottom="48dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnContinueWithGoogle"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Continue with Google"
        android:textAllCaps="false"
        android:textColor="?attr/colorTextPrimary"
        app:backgroundTint="?attr/colorButtonPrimary"
        app:cornerRadius="16dp"
        android:layout_marginBottom="16dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnContinueWithoutLogin"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Continue without login (Offline)"
        android:textAllCaps="false"
        android:textColor="?attr/colorTextSecondary"
        app:backgroundTint="?attr/colorCardSurface"
        app:strokeColor="?attr/colorCardStroke"
        app:strokeWidth="1dp"
        app:cornerRadius="16dp" />
</LinearLayout>
